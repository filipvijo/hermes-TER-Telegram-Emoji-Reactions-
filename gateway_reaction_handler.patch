     # ── Message reactions (processing lifecycle) ──────────────────────────
+    async def _handle_message_reaction(
+        self, update: "Update", context: "ContextTypes.DEFAULT_TYPE"
+    ) -> None:
+        """Handle emoji reactions on messages sent by Hermes."""
+        if not self._reactions_enabled():
+            return
+
+        reaction = getattr(update, "message_reaction", None)
+        if not reaction:
+            return
+
+        new_reactions = getattr(reaction, "new_reaction", []) or []
+        if not new_reactions:
+            return
+
+        # Extract emoji (ignore custom emoji / paid reactions)
+        emoji = None
+        for r in new_reactions:
+            emoji = getattr(r, "emoji", None)
+            if emoji:
+                break
+        if not emoji:
+            return
+
+        chat_id = getattr(getattr(reaction, "chat", None), "id", None)
+        message_id = getattr(reaction, "message_id", None)
+        if chat_id is None or message_id is None:
+            return
+
+        logger.info("[%s] Reaction %s on msg %s chat %s", self.name, emoji, message_id, chat_id)
+
+        # Look up original message text from cache
+        original_text = self._sent_message_cache.get((int(chat_id), int(message_id)), "")
+        if not original_text:
+            return
+
+        try:
+            import asyncio
+            from tools.telegram_reaction_tool import _generate_response
+
+            # Run sync generation in thread pool to avoid blocking event loop
+            response = await asyncio.to_thread(_generate_response, original_text, emoji)
+            if not response:
+                return
+
+            resp_type = response.get("type")
+            resp_url = response.get("url")
+            resp_text = response.get("text")
+
+            if resp_type == "animation" and resp_url:
+                try:
+                    await self._bot.send_animation(
+                        chat_id=int(chat_id),
+                        animation=resp_url,
+                        reply_to_message_id=int(message_id),
+                        caption=resp_text or "",
+                    )
+                except Exception:
+                    if resp_text:
+                        await self._bot.send_message(
+                            chat_id=int(chat_id),
+                            text=resp_text,
+                            reply_to_message_id=int(message_id),
+                        )
+            elif resp_text:
+                await self._bot.send_message(
+                    chat_id=int(chat_id),
+                    text=resp_text,
+                    reply_to_message_id=int(message_id),
+                )
+        except Exception as exc:
+            logger.debug("[%s] Reaction response failed: %s", self.name, exc)
 
     def _reactions_enabled(self) -> bool:
         """Check if message reactions are enabled via config/env."""
